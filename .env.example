# Project / vault (not auto-loaded — export in shell or MCP env)
# AIO_PROJECT_ROOT=
# AIO_VAULT_PATH=./vault
# OBSIDIAN_VAULT_PATH=./vault
# AIO_VAULT_NAME=

# Embedding provider (local - no key needed, openai - needs OPENAI_API_KEY)
# Default: local (fully offline, first run downloads model ~30MB)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Xenova/multilingual-e5-small

# OpenAI embedding (optional - higher quality, needs API key)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# ── Vector store ──────────────────────────────────────────────
# Default: local FAISS under vault/.index
# VECTOR_STORE=faiss
# Shared naming (optional): VECTOR_COLLECTION=my_col  VECTOR_COLLECTION_PREFIX=aio
#
# Qdrant
# VECTOR_STORE=qdrant
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=
#
# Chroma
# VECTOR_STORE=chroma
# CHROMA_URL=http://127.0.0.1:8000
# CHROMA_API_KEY=
# CHROMA_API=v2
# CHROMA_COLLECTION=
#
# Pinecone
# VECTOR_STORE=pinecone
# PINECONE_API_KEY=
# PINECONE_INDEX=aio-vault
# PINECONE_HOST=                 # optional; auto-discovered from control plane
# PINECONE_NAMESPACE=
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
#
# Weaviate
# VECTOR_STORE=weaviate
# WEAVIATE_URL=http://127.0.0.1:8080
# WEAVIATE_API_KEY=
# WEAVIATE_CLASS=Aio_vault
#
# PostgreSQL + pgvector (requires: npm i pg)
# VECTOR_STORE=pgvector
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/aio
# PGVECTOR_TABLE=aio_vectors

# MCP SSE: `aio serve --host/--port` (defaults 127.0.0.1:8910)
# Non-localhost bind requires a token (or AIO_SSE_ALLOW_INSECURE=1)
# AIO_SSE_TOKEN=
# AIO_SSE_ALLOW_INSECURE=0

# Dashboard: `aio dashboard --host/--port` (defaults 127.0.0.1:8920)
# Non-localhost bind requires a token (or AIO_DASHBOARD_ALLOW_INSECURE=1)
# AIO_DASHBOARD_TOKEN=
# AIO_DASHBOARD_ALLOW_INSECURE=0

# Approval / child-session hardening (defaults are secure)
# AIO_ALLOW_SKIP_APPROVAL=0
# AIO_ALLOW_MCP_APPROVAL_RESOLVE=0
# AIO_ALLOW_REPORT_WITHOUT_SECRET=0
# AIO_ALLOW_EXTERNAL_VAULT_PATH=0
# AIO_CHILD_ENV_PASSTHROUGH=0
# AIO_CHILD_ENV_EXTRA=
# AIO_ALLOW_UNTRUSTED_EMBEDDING_MODEL=0

# Sessions / harness
# AIO_SESSION_RUNTIME=
# AIO_HARNESS_TARGET=
# AIO_EVENTS=0
