{
  "name": "@mindol1004/aio-mcp",
  "version": "2.12.0",
  "description": "AI Orchestration System - TypeScript rewrite",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "aio": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:all": "npm run typecheck && npm run lint && npm run format:check",
    "wiki-lint": "node dist/cli.js wiki-lint --fail",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ai",
    "orchestration",
    "mcp",
    "dag",
    "ralph-loop",
    "wiki"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "faiss-node": "^0.5.1",
    "ioredis": "^5.3.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "ora": "^8.0.0",
    "uuid": "^14.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "faiss-node@0.5.1": true,
    "sharp@0.32.6": true,
    "protobufjs@7.6.5": true
  }
}
